{
	"name": "memscripture",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && printf '_worker.js\\n_routes.json\\n_headers\\n' > .svelte-kit/cloudflare/.assetsignore",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.6.0",
		"@vitest/ui": "^4.1.5",
		"fake-indexeddb": "^6.2.5",
		"jsdom": "^29.1.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.5",
		"wrangler": "^4.88.0"
	},
	"dependencies": {
		"dexie": "^4.4.2",
		"lucide-svelte": "^1.0.1"
	}
}
